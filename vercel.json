{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/booking.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/contact.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/booking", "destination": "/api/booking" },
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
